<Window x:Class="MedicalSegmentationPSO.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Medical Segmentation - PSO Engine"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

	<Border CornerRadius="18" Background="#0F172A">
		<Grid>
			<Grid.Background>
				<RadialGradientBrush>
					<GradientStop Color="#1E293B" Offset="0"/>
					<GradientStop Color="#0F172A" Offset="1"/>
				</RadialGradientBrush>
			</Grid.Background>

			<Grid.Resources>
				<Style TargetType="Button">
					<Setter Property="Foreground" Value="White"/>
					<Setter Property="FontSize" Value="13"/>
					<Setter Property="Padding" Value="14,8"/>
					<Setter Property="Cursor" Value="Hand"/>
					<Setter Property="BorderThickness" Value="0"/>
					<Setter Property="Background" Value="#334155"/>
					<Setter Property="Template">
						<Setter.Value>
							<ControlTemplate TargetType="Button">
								<Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="12"
                                        Padding="{TemplateBinding Padding}">
									<ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
								</Border>
								<ControlTemplate.Triggers>
									<Trigger Property="IsMouseOver" Value="True">
										<Setter TargetName="bd" Property="Background" Value="#38BDF8"/>
									</Trigger>
									<Trigger Property="IsPressed" Value="True">
										<Setter TargetName="bd" Property="Background" Value="#0EA5E9"/>
									</Trigger>
									<Trigger Property="IsEnabled" Value="False">
										<Setter TargetName="bd" Property="Background" Value="#1E293B"/>
										<Setter Property="Foreground" Value="#475569"/>
									</Trigger>
								</ControlTemplate.Triggers>
							</ControlTemplate>
						</Setter.Value>
					</Setter>
				</Style>

				<!-- Progress bar style -->
				<Style TargetType="ProgressBar">
					<Setter Property="Height" Value="6"/>
					<Setter Property="Background" Value="#1E293B"/>
					<Setter Property="Foreground" Value="#38BDF8"/>
					<Setter Property="BorderThickness" Value="0"/>
					<Setter Property="Template">
						<Setter.Value>
							<ControlTemplate TargetType="ProgressBar">
								<Border CornerRadius="3" Background="{TemplateBinding Background}">
									<Border x:Name="PART_Track">
										<Border x:Name="PART_Indicator"
                                                HorizontalAlignment="Left"
                                                Background="{TemplateBinding Foreground}"
                                                CornerRadius="3"/>
									</Border>
								</Border>
							</ControlTemplate>
						</Setter.Value>
					</Setter>
				</Style>
			</Grid.Resources>

			<Grid Margin="18">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>

				<!-- HEADER -->
				<Grid Grid.Row="0" Margin="0,0,0,15">
					<Grid.ColumnDefinitions>
						<ColumnDefinition/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBlock Text="🧠 Medical Segmentation + Classification Engine"
                               Foreground="White" FontSize="22" FontWeight="Bold"
                               VerticalAlignment="Center"/>
					<StackPanel Grid.Column="1" Orientation="Horizontal">
						<Button Content="—" Width="38" Height="30" Margin="4,0"
                                Background="#334155" Click="Minimize_Click"/>
						<Button Content="✕" Width="38" Height="30"
                                Background="#EF4444" Click="Close_Click"/>
					</StackPanel>
				</Grid>

				<!-- SCROLLABLE CONTENT -->
				<ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
					<StackPanel>

						<!-- ── ACTION PANEL ── -->
						<Border Background="#1E293B" CornerRadius="16"
                                Padding="16" Margin="0,0,0,12">
							<StackPanel>
								<Button Content="📂  Load MRI / CT Image"
                                        Background="#3B82F6" FontWeight="Bold"
                                        Height="44" Click="BtnBrowse_Click"/>

								<!-- PROGRESS BAR (hidden until processing) -->
								<Grid Margin="0,10,0,0" x:Name="pnlProgress" Visibility="Collapsed">
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto"/>
										<RowDefinition Height="Auto"/>
									</Grid.RowDefinitions>
									<TextBlock x:Name="txtProgress"
                                               Grid.Row="0"
                                               Foreground="#38BDF8"
                                               FontSize="12"
                                               Margin="0,0,0,4"
                                               Text="Processing…"/>
									<ProgressBar x:Name="progressBar"
                                                 Grid.Row="1"
                                                 IsIndeterminate="True"/>
								</Grid>

								<TextBlock Text="▸ Run Individual Algorithm"
                                           Foreground="#64748B" FontSize="12"
                                           Margin="0,12,0,4"/>
								<WrapPanel HorizontalAlignment="Center">
									<Button Content="Sequential PSO"  Margin="5" Click="BtnSequential_Click" FontWeight="Bold"/>
									<Button Content="Multi-Core PSO"  Margin="5" Click="BtnMultiCore_Click"  FontWeight="Bold"/>
									<Button Content="PLINQ PSO"       Margin="5" Click="BtnPLINQ_Click"      FontWeight="Bold"/>
									<Button Content="Shared Memory"   Margin="5" Click="BtnShared_Click"     FontWeight="Bold"/>
									<Button Content="GPU Accel"       Margin="5" Click="BtnGPU_Click"        FontWeight="Bold"/>
								</WrapPanel>

								<TextBlock Text="▸ Batch Operations"
                                           Foreground="#64748B" FontSize="12"
                                           Margin="0,12,0,4"/>
								<WrapPanel HorizontalAlignment="Center">
									<Button x:Name="btnRunAll"
                                            Content="🔄  Run All &amp; Compare"
                                            Background="#8B5CF6"
                                            FontWeight="Bold" Margin="5"
                                            Click="BtnRunAll_Click"/>
									<Button Content="⏱  Benchmark (3× each)"
                                            Background="#10B981"
                                            FontWeight="Bold" Margin="5"
                                            Click="BtnBenchmark3_Click"/>
									<Button Content="💾  Save Segmented Image"
                                            Background="#0F766E"
                                            FontWeight="Bold" Margin="5"
                                            Click="BtnSaveSegmented_Click"/>
								</WrapPanel>
							</StackPanel>
						</Border>

						<!-- ── IMAGE PANEL ── -->
						<Grid Margin="0,0,0,12">
							<Grid.ColumnDefinitions>
								<ColumnDefinition/>
								<ColumnDefinition/>
							</Grid.ColumnDefinitions>

							<Border Grid.Column="0" Background="#111827"
                                    CornerRadius="16" Padding="12" Margin="0,0,6,0">
								<StackPanel>
									<TextBlock Text="Original MRI / CT Scan"
                                               Foreground="#94A3B8" FontWeight="Bold" Margin="5"/>
									<Border CornerRadius="10" ClipToBounds="True">
										<Image x:Name="imgOriginal" Height="300" Stretch="Uniform"/>
									</Border>
								</StackPanel>
							</Border>

							<Border Grid.Column="1" Background="#111827"
                                    CornerRadius="16" Padding="12" Margin="6,0,0,0">
								<StackPanel>
									<TextBlock Text="PSO Segmentation Output (Tumor Highlighted)"
                                               Foreground="#94A3B8" FontWeight="Bold" Margin="5"/>
									<Border CornerRadius="10" ClipToBounds="True">
										<Image x:Name="imgSegmented" Height="300" Stretch="Uniform"/>
									</Border>
								</StackPanel>
							</Border>
						</Grid>

						<!-- ── CNN CLASSIFICATION PANEL ── -->
						<Border Background="#1E293B" CornerRadius="16"
                                Padding="16" Margin="0,0,0,12">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>

								<StackPanel>
									<TextBlock Text="🏥  CNN Tumor Classification"
                                               Foreground="White" FontSize="16"
                                               FontWeight="Bold" Margin="0,0,0,8"/>
									<TextBlock x:Name="txtClassification"
                                               Foreground="#F0ABFC"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Text="Prediction: —"/>
									<TextBlock x:Name="txtClassNote"
                                               Foreground="#94A3B8"
                                               FontSize="12"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               Text="Load an image first, then click Classify."/>
								</StackPanel>

								<StackPanel Grid.Column="1" VerticalAlignment="Center">
									<Button x:Name="btnClassify"
                                            Content="🧠  Classify Tumor"
                                            Background="#9333EA" FontWeight="Bold"
                                            IsEnabled="False"
                                            Width="170"
                                            Click="BtnClassify_Click"/>
								</StackPanel>
							</Grid>
						</Border>

						<!-- ── SINGLE-RUN RESULTS ── -->
						<Border Background="#1E293B" CornerRadius="16"
                                Padding="16" Margin="0,0,0,12">
							<StackPanel>
								<TextBlock Text="📊  Processing Results"
                                           Foreground="White" FontSize="16"
                                           FontWeight="Bold" Margin="0,0,0,8"/>

								<TextBlock x:Name="txtStatus"
                                           Foreground="#CBD5E1" FontSize="14" Margin="0,3"/>
								<TextBlock x:Name="txtTime"
                                           Foreground="#60A5FA" FontSize="14"
                                           FontWeight="SemiBold" Margin="0,3"/>
								<TextBlock x:Name="txtAvgTime"
                                           Foreground="#60A5FA" FontSize="14"
                                           FontWeight="SemiBold" Margin="0,3"/>
								<TextBlock x:Name="txtSpeedup"
                                           Foreground="#34D399" FontSize="14"
                                           FontWeight="SemiBold" Margin="0,3"/>
								<TextBlock x:Name="txtEfficiency"
                                           Foreground="#34D399" FontSize="14"
                                           FontWeight="SemiBold" Margin="0,3"/>
								<TextBlock x:Name="txtCores"
                                           Foreground="#FBBF24" FontSize="14"
                                           FontWeight="SemiBold" Margin="0,3"/>
								<TextBlock x:Name="txtTumor"
                                           Foreground="#CBD5E1" FontSize="13"
                                           Margin="0,6,0,0" TextWrapping="Wrap"/>
							</StackPanel>
						</Border>

						<!-- ── ALL-ALGORITHM COMPARISON TABLE ── -->
						<Border x:Name="pnlComparison"
                                Background="#1E293B" CornerRadius="16"
                                Padding="16" Margin="0,0,0,12"
                                Visibility="Collapsed">
							<StackPanel>
								<TextBlock Text="🔄  Algorithm Comparison"
                                           Foreground="White" FontSize="16"
                                           FontWeight="Bold" Margin="0,0,0,12"/>

								<Grid Margin="0,0,0,4">
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="*"/>
										<ColumnDefinition Width="130"/>
										<ColumnDefinition Width="100"/>
										<ColumnDefinition Width="110"/>
									</Grid.ColumnDefinitions>
									<TextBlock Grid.Column="0" Text="Algorithm"  Foreground="#94A3B8" FontWeight="Bold"/>
									<TextBlock Grid.Column="1" Text="Time (ms)"  Foreground="#94A3B8" FontWeight="Bold" TextAlignment="Right"/>
									<TextBlock Grid.Column="2" Text="Speedup"    Foreground="#94A3B8" FontWeight="Bold" TextAlignment="Right"/>
									<TextBlock Grid.Column="3" Text="Efficiency" Foreground="#94A3B8" FontWeight="Bold" TextAlignment="Right"/>
								</Grid>

								<Rectangle Height="1" Fill="#334155" Margin="0,4"/>
								<StackPanel x:Name="spComparisonRows"/>
								<Rectangle Height="1" Fill="#334155" Margin="0,8"/>
								<TextBlock x:Name="txtComparisonNote"
                                           Foreground="#64748B" FontSize="12"
                                           TextWrapping="Wrap"/>
							</StackPanel>
						</Border>

					</StackPanel>
				</ScrollViewer>
			</Grid>
		</Grid>
	</Border>
</Window>
